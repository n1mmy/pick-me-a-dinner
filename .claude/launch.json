{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "pick-me-a-dinner",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true,
      "env": {
        "DATABASE_URL": "postgresql://dinner:dinner@localhost:5432/pick-me-a-dinner?schema=public"
      }
    },
    {
      "name": "local-build",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "npm run build && npm run start"],
      "port": 3000,
      "env": {
        "DATABASE_URL": "postgresql://dinner:dinner@localhost:5432/pick-me-a-dinner?schema=public"
      }
    }
  ]
}
